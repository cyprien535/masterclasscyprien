generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Registration {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  email     String   @unique
    whatsApp   String
  mailSent   Boolean @default(false)
  createdAt DateTime @default(now())
}
